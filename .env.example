# Secrets de control-mayu. Copiar a .env.local y completar con los valores reales.
# En produccion, setear en Netlify: Site settings -> Environment variables.
# Si faltan, la funcion sendWhatsAppNotification loggea warning y omite el envio (la app sigue funcionando).

VITE_MAKE_WEBHOOK_URL=
VITE_WHATSAPP_GROUP_ID=
